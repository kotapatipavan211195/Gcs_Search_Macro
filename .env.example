# Set APP_ENV=production only behind the IAP-protected load balancer.
APP_ENV=development
GOOGLE_CLOUD_PROJECT=your-project
GCS_SEARCH_REPORTS_BUCKET=your-private-reports-bucket
GCS_SEARCH_TASKS_LOCATION=us-central1
GCS_SEARCH_TASKS_QUEUE=gcs-search-jobs
GCS_SEARCH_WORKER_URL=http://localhost:8081
GCS_SEARCH_TASK_SERVICE_ACCOUNT=cloud-tasks-invoker@your-project.iam.gserviceaccount.com

# A JSON object whose keys are scope IDs.  Users can submit only these scopes.
# Every scope gets a fixed project, DAG/inventory tables, buckets, and policy.
GCS_SEARCH_SCOPE_POLICIES_JSON='{"analytics":{"project":"acme-analytics-dev","buckets":[{"name":"acme-datalake-scripts","prefix":""}],"dag_table":"acme-analytics-dev.pipeline_metadata.dag_script_status","job_inventory_table":"acme-analytics-dev.pipeline_metadata.data_lake_job_inventory","exclude_keywords":["load","backup","archive/"],"exclude_patterns":[],"copy_targets":{"review":{"bucket":"acme-review-staging","prefix":"gcs-search"}}}}'

GCS_SEARCH_ALLOWED_EMAIL_DOMAINS=example.com
GCS_SEARCH_MAX_TERMS=20
GCS_SEARCH_MAX_TERM_LENGTH=200
GCS_SEARCH_MAX_BUCKET_PATHS=20
GCS_SEARCH_MAX_FILES_PER_JOB=100000
GCS_SEARCH_MAX_FILE_BYTES=10485760
GCS_SEARCH_MAX_RESULT_ROWS=100000
GCS_SEARCH_SEARCH_WORKERS=16
GCS_SEARCH_COPY_WORKERS=8
GCS_SEARCH_MAX_INVENTORY_ROWS=100000
GCS_SEARCH_CACHE_DATASET=gcs_search_cache

# Optional organization SMTP relay (store credentials in Secret Manager).
GCS_SEARCH_SMTP_HOST=
GCS_SEARCH_SMTP_PORT=587
GCS_SEARCH_SMTP_USER=
GCS_SEARCH_SMTP_PASSWORD=
GCS_SEARCH_SMTP_FROM=
GCS_SEARCH_SMTP_USE_TLS=true
